{
  "version": 1,
  "commands": [
    {
      "yarnName": "goto",
      "documentation": "Replace the current node frame with the target node. Use for lateral or cycling navigation where you do not want to return to the calling node. Contrast with <<jump>> which pushes and returns.",
      "parameters": [
        { "name": "node_name", "type": "string" }
      ]
    },
    {
      "yarnName": "give_item",
      "documentation": "Add an item to the player's inventory.",
      "parameters": [
        { "name": "item_id", "type": "string" },
        { "name": "count",   "type": "number" }
      ]
    },
    {
      "yarnName": "take_item",
      "documentation": "Remove an item from the player's inventory.",
      "parameters": [
        { "name": "item_id", "type": "string" },
        { "name": "count",   "type": "number" }
      ]
    },
    {
      "yarnName": "add_effect",
      "documentation": "Apply an effect to the player.",
      "parameters": [
        { "name": "effect_id",      "type": "string" },
        { "name": "duration_turns", "type": "number" }
      ]
    },
    {
      "yarnName": "remove_effect",
      "documentation": "Remove an effect from the player.",
      "parameters": [
        { "name": "effect_id", "type": "string" }
      ]
    },
    {
      "yarnName": "npc_follow",
      "documentation": "Make the NPC follow the player.",
      "parameters": []
    },
    {
      "yarnName": "npc_stop_follow",
      "documentation": "Make the NPC stop following the player.",
      "parameters": []
    },
    {
      "yarnName": "npc_set_attitude",
      "documentation": "Set the NPC's attitude (e.g. NPCATT_FOLLOW, NPCATT_KILL).",
      "parameters": [
        { "name": "attitude_id", "type": "string" }
      ]
    },
    {
      "yarnName": "u_set_var",
      "documentation": "Store a value in the player's variable bag. Accepts string, number, or bool.",
      "parameters": [
        { "name": "key",   "type": "string" },
        { "name": "value", "type": "string" }
      ]
    },
    {
      "yarnName": "u_remove_var",
      "documentation": "Delete a variable from the player's variable bag.",
      "parameters": [
        { "name": "key", "type": "string" }
      ]
    },
    {
      "yarnName": "u_adjust_var",
      "documentation": "Add an amount to a numeric variable in the player's variable bag.",
      "parameters": [
        { "name": "key",    "type": "string" },
        { "name": "amount", "type": "number" }
      ]
    },
    {
      "yarnName": "npc_set_var",
      "documentation": "Store a value in the NPC's variable bag. Accepts string, number, or bool.",
      "parameters": [
        { "name": "key",   "type": "string" },
        { "name": "value", "type": "string" }
      ]
    },
    {
      "yarnName": "npc_remove_var",
      "documentation": "Delete a variable from the NPC's variable bag.",
      "parameters": [
        { "name": "key", "type": "string" }
      ]
    },
    {
      "yarnName": "npc_adjust_var",
      "documentation": "Add an amount to a numeric variable in the NPC's variable bag.",
      "parameters": [
        { "name": "key",    "type": "string" },
        { "name": "amount", "type": "number" }
      ]
    }
  ],
  "functions": [
    {
      "yarnName": "u_has_trait",
      "documentation": "Returns true if the player has the given mutation/trait.",
      "parameters": [ { "name": "trait_id", "type": "string" } ],
      "return": { "type": "bool" }
    },
    {
      "yarnName": "u_has_effect",
      "documentation": "Returns true if the player has the given effect active.",
      "parameters": [ { "name": "effect_id", "type": "string" } ],
      "return": { "type": "bool" }
    },
    {
      "yarnName": "u_has_bionic",
      "documentation": "Returns true if the player has the given bionic installed.",
      "parameters": [ { "name": "bionic_id", "type": "string" } ],
      "return": { "type": "bool" }
    },
    {
      "yarnName": "u_has_item",
      "documentation": "Returns true if the player has at least one of the given item.",
      "parameters": [ { "name": "item_id", "type": "string" } ],
      "return": { "type": "bool" }
    },
    {
      "yarnName": "u_has_items",
      "documentation": "Returns true if the player has at least count of the given item.",
      "parameters": [
        { "name": "item_id", "type": "string" },
        { "name": "count",   "type": "number" }
      ],
      "return": { "type": "bool" }
    },
    {
      "yarnName": "u_has_skill",
      "documentation": "Returns true if the player's skill level is >= the given level.",
      "parameters": [
        { "name": "skill_id", "type": "string" },
        { "name": "level",    "type": "number" }
      ],
      "return": { "type": "bool" }
    },
    {
      "yarnName": "u_get_str",
      "documentation": "Returns the player's current Strength value.",
      "parameters": [],
      "return": { "type": "number" }
    },
    {
      "yarnName": "u_get_dex",
